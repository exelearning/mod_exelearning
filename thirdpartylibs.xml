<?xml version="1.0"?>
<!-- Note: the eXeLearning static editor lives under dist/static/ but is NOT
     committed to the repository (see .gitignore); it is fetched at build/release
     time or installed from GitHub by an admin. It is therefore NOT declared here,
     because Moodle's `grunt ignorefiles` stats every <location> and aborts on a
     missing path, which breaks `moodle-plugin-ci install`. When dist/static/ is
     bundled into a release zip, scripts/package.sh stamps a dist/static
     declaration into the ZIP's copy of this file automatically. -->
<libraries>
  <library>
    <location>assets/scorm/SCORM_API_wrapper.js</location>
    <name>pipwerks SCORM API Wrapper</name>
    <description>pipwerks SCORM wrapper used to bridge gradable iDevices with the LMS SCORM runtime.</description>
    <version>1.1.20121006</version>
    <license>MIT</license>
  </library>
  <library>
    <location>assets/scorm/SCOFunctions.js</location>
    <name>pipwerks SCO Functions</name>
    <description>pipwerks helper functions wrapping the SCORM API wrapper for gradable iDevices.</description>
    <version>1.1.20121006</version>
    <license>MIT</license>
  </library>
</libraries>
