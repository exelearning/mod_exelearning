{
    "name": "exelearning/mod_exelearning",
    "description": "Activity-type Moodle plugin to embed eXeLearning v4 packages preserving the native sidebar and recording multiple gradable items per resource.",
    "type": "moodle-plugin",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/exelearning/mod_exelearning",
    "support": {
        "issues": "https://github.com/exelearning/mod_exelearning/issues",
        "source": "https://github.com/exelearning/mod_exelearning"
    },
    "keywords": [
        "moodle",
        "moodle-plugin",
        "exelearning",
        "scorm",
        "xapi"
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "moodlehq/moodle-cs": "^v3.4",
        "phpmd/phpmd": "^2.15",
        "phpunit/phpunit": "^10.5 || ^11.5",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "scripts": {
        "lint": "phpcs --standard=moodle --ignore=*/dist/*,*/research/*,*/node_modules/*,*/vendor/*,*/amd/build/*,*.min.* .",
        "fix":  "phpcbf --standard=moodle --ignore=*/dist/*,*/research/*,*/node_modules/*,*/vendor/*,*/amd/build/*,*.min.* .",
        "phpmd": "phpmd . text phpmd.xml || true",
        "test": "phpunit --colors",
        "behat": "behat --colors",
        "coverage": "phpunit --coverage-text"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
