<?xml version="1.0"?>
<ruleset name="mod_exelearning">
    <description>Coding standard for the mod_exelearning plugin (Moodle standard).</description>

    <!-- Scan the whole plugin by default. -->
    <file>.</file>

    <!-- Use the Moodle coding standard. -->
    <rule ref="moodle"/>

    <!-- Bundled, generated or third-party code is not subject to the standard. -->
    <exclude-pattern>*/dist/*</exclude-pattern>
    <exclude-pattern>*/research/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/amd/build/*</exclude-pattern>
    <exclude-pattern>*.min.*</exclude-pattern>
</ruleset>
